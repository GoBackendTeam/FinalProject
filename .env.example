# --- HTTP ---
HTTP_ADDR=:8080
GIN_MODE=debug

# --- Database (PostgreSQL) ---
# 本機跑 app + compose 跑 db 時用 localhost;app 也在 compose 內時用服務名 db
DATABASE_URL=postgres://regs:regs@localhost:5433/regs?sslmode=disable

# --- JWT (ES256 / EC P-256) ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_TTL_HOURS=12

# --- Judge engine ---
# 題庫根目錄(內含 113final00X 等題目)
PROBLEMS_ROOT=./problems
# 與 PROBLEMS_ROOT 對應的「主機」路徑(bind mount 用)。
# app 直接跑在 host 時留空;app 在容器內(DooD)時填主機真實路徑。
PROBLEMS_ROOT_HOST=
# 評測工作目錄(每個提交一個子目錄):app 視角的路徑
JUDGE_WORKSPACE=./workspace
# 與 JUDGE_WORKSPACE 對應的「主機」路徑(bind mount 用)。
# app 直接跑在 host 時留空;app 在容器內(DooD)時填主機真實路徑。
JUDGE_WORKSPACE_HOST=
# 編譯/執行容器映像(內含 Clang/CMake/Ninja)
JUDGE_IMAGE=yhlib/cs3060701
# 強制容器平台。yhlib/cs3060701 只有 amd64,Apple Silicon 需設 linux/amd64
# (Docker Desktop 透過 Rosetta/QEMU 模擬)。amd64 主機填 linux/amd64 為 no-op。
JUDGE_PLATFORM=linux/amd64
# 最大同時評測容器數(Semaphore)
JUDGE_MAX_CONCURRENCY=2
# 每個 case 的執行逾時(秒)
JUDGE_CASE_TIMEOUT=10
# 編譯/設定階段逾時(秒)
JUDGE_BUILD_TIMEOUT=120
# 編譯容器使用的 docker network 名稱(會自動建立),執行容器固定 none
JUDGE_BUILD_NETWORK=regs-build
